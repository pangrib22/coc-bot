# ── WAJIB DIISI ──────────────────────────────────────────────
# Copy dari DevTools > Headers > Authorization (tanpa kata "Bearer")
BEARER_TOKEN=eyJhbGciOiJFUzI1NiIsInR5cCI6IkpXVCJ...

# ── OPSIONAL (ada default-nya) ───────────────────────────────
# Mode bot: "free" (claim gratis saja) atau "attack" (serang musuh juga)
BOT_MODE=free

# Jeda antar aksi dalam detik (minimal 30 supaya tidak kena ban)
BOT_INTERVAL=30

# Maksimal territory yang mau dikuasai
MAX_TERRITORIES=50

# Level log: INFO / DEBUG
LOG_LEVEL=INFO
